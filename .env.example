# ==========================================
# rApanel — Configuración del Panel
# ==========================================
# Copia este archivo como .env y completa los valores.
# Después de cualquier cambio ejecuta:
#   php artisan config:clear && php artisan cache:clear

# ------------------------------------------
# APLICACIÓN
# ------------------------------------------

APP_NAME=rApanel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# Nombre del servidor mostrado en el panel
RA_SERVER_NAME=RAGNAROK

# Zona horaria — lista completa: https://www.php.net/manual/es/timezones.php
APP_TIMEZONE=UTC

# Idioma por defecto (disponibles: en, es, pt, fr)
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ------------------------------------------
# BASE DE DATOS (rAthena)
# ------------------------------------------
# Apunta a la misma base de datos de tu servidor rAthena.
# El panel creará sus propias tablas con prefijo ra_ en esa misma BD.

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ragnarok
DB_USERNAME=ragnarok
DB_PASSWORD=ragnarok

# Base de datos de logs de rAthena (usualmente la misma)
DB_LOG_HOST=127.0.0.1
DB_LOG_PORT=3306
DB_LOG_DATABASE=ragnarok
DB_LOG_USERNAME=ragnarok
DB_LOG_PASSWORD=ragnarok

# Base de datos web de rAthena (usualmente la misma)
DB_WEB_HOST=127.0.0.1
DB_WEB_PORT=3306
DB_WEB_DATABASE=ragnarok
DB_WEB_USERNAME=ragnarok
DB_WEB_PASSWORD=ragnarok

# ------------------------------------------
# EMULADOR Y MODO DE JUEGO
# ------------------------------------------

# Emulador del servidor: rathena | hercules
RA_EMULATOR=rathena

# Modo de juego: renewal | pre-renewal
RA_GAME_MODE=renewal

# ------------------------------------------
# SERVIDORES rAthena (IPs y puertos)
# ------------------------------------------

RA_LOGIN_IP=127.0.0.1
RA_LOGIN_PORT=6900

RA_CHAR_IP=127.0.0.1
RA_CHAR_PORT=6121

RA_MAP_IP=127.0.0.1
RA_MAP_PORT=5121

RA_WEB_IP=127.0.0.1
RA_WEB_PORT=8080

# ------------------------------------------
# CUENTAS Y PERSONAJES
# ------------------------------------------

# rAthena es case-insensitive por defecto (no distingue mayúsculas en el userid)
RA_ACCOUNT_NOCASE=true

# Usar MD5 para contraseñas de cuentas de juego (recomendado: true para rAthena estándar)
RA_USE_MD5_PASSWORDS=true

# Máximo de cuentas de juego por cuenta maestra del panel
RA_MAX_GAME_ACCOUNTS=3

# Mapa y coordenadas de reset de personaje (usados al resetear posición desde el panel)
RA_RESET_MAP=prontera
RA_RESET_X=150
RA_RESET_Y=180

# ------------------------------------------
# FUNCIONALIDADES DEL PANEL
# ------------------------------------------

# Requerir verificación de email al registrarse
RA_REQUIRE_EMAIL_VERIFY=false

# ------------------------------------------
# DOBLE FACTOR DE AUTENTICACIÓN (2FA)
# ------------------------------------------
# RA_2FA_ENABLED      → Permite a cualquier usuario activar 2FA voluntariamente
#                       desde su perfil (Google Authenticator, Authy, etc.)
# RA_2FA_FORCE_ADMINS → Obliga a todos los usuarios con rol Admin a configurar
#                       2FA antes de poder acceder al panel de administración.
#                       Requiere que RA_2FA_ENABLED también sea true.

RA_2FA_ENABLED=false
RA_2FA_FORCE_ADMINS=false

# Minutos de inactividad antes de cerrar sesión automáticamente (0 = desactivado)
RA_INACTIVITY_TIMEOUT=30

# Funciones adicionales (habilitar según las tablas que tenga tu rAthena)
RA_VIP_ENABLED=false
RA_BANK_ENABLED=false
RA_CASHPOINTS_ENABLED=false

# Ruta al archivo de log del servidor rAthena (para la consola de admin)
RA_LOG_PATH=

# Console Live Monitor — ws-server corre en el mismo host que rAthena (RA_LOGIN_IP).
# El host se detecta automáticamente desde RA_LOGIN_IP; solo configura puerto y secreto.
RA_WS_PORT=3001
RA_WS_SECRET=
RA_WS_INTERNAL_URL=http://127.0.0.1:3001
RA_WS_PUBLIC_URL=wss://mi-servidor.com/ws-proxy

# ------------------------------------------
# DISCORD
# ------------------------------------------
# Muestra un widget de Discord en la sección "Stay Update" del Home.
# El bot token permite mostrar el conteo de miembros y en línea en tiempo real.
#
# 1. Crea una aplicación en https://discord.com/developers/applications
# 2. Ve a "Bot" y copia el Token
# 3. Invita el bot a tu servidor con permisos de "Read Members"
# 4. El Server ID lo encuentras haciendo clic derecho en tu servidor → "Copiar ID"
#    (requiere tener el modo desarrollador activado en Discord)
# 5. El Invite URL es el enlace de invitación a tu servidor para el botón "Join"

DISCORD_BOT_TOKEN=
DISCORD_SERVER_ID=
DISCORD_INVITE_URL=

# ------------------------------------------
# GEOLOCALIZACIÓN (Dashboard Administrador)
# ------------------------------------------
# Muestra en el dashboard de admin un mapa mundial con la distribución de jugadores.
# Requiere MaxMind GeoLite2 (gratis con registro).
#
# 1. Regístrate en https://www.maxmind.com/en/geolite2/signup
# 2. Obtén tu User ID y License Key en tu cuenta MaxMind
# 3. Descarga la base de datos local con: php artisan location:update
# 4. Sin credenciales el mapa simplemente aparecerá en blanco.

GEOLOCATION_DRIVER=maxmind_database
MAXMIND_USER_ID=
MAXMIND_LICENSE_KEY=

# ------------------------------------------
# SESIONES Y CACHÉ
# ------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# ------------------------------------------
# CORREO ELECTRÓNICO
# ------------------------------------------
# Usado para: verificación de email al registrarse y recuperación de contraseña.
# Solo tiene efecto si RA_REQUIRE_EMAIL_VERIFY=true o si un usuario solicita
# recuperar su contraseña desde el formulario de login.
#
# MAIL_MAILER:
#   smtp  → Envío real por tu servidor de correo (producción)
#   log   → Solo escribe en storage/logs/laravel.log, no envía nada (desarrollo)
#           Útil para probar el flujo de registro sin necesitar un servidor de correo.
#
# MAIL_SCHEME según el puerto de tu proveedor:
#   smtps → Puerto 465  (SSL implícito)  ← el más común en hosting compartido
#   tls   → Puerto 587  (STARTTLS)       ← Gmail, Outlook, SendGrid, Mailgun
#   (dejar vacío) → Puerto 25 sin cifrado (no recomendado en producción)
#
# Ejemplos por proveedor:
#   Hosting compartido (cPanel/Plesk):
#     MAIL_SCHEME=smtps | MAIL_PORT=465
#   Gmail (App Password):
#     MAIL_HOST=smtp.gmail.com | MAIL_SCHEME=tls | MAIL_PORT=587
#   Mailtrap (pruebas):
#     MAIL_HOST=sandbox.smtp.mailtrap.io | MAIL_SCHEME=tls | MAIL_PORT=587
#
# ⚠ Si tu contraseña contiene caracteres especiales ($ ; @ # etc.),
#   enciérrala siempre en comillas simples: MAIL_PASSWORD='tu$clave;aqui'

MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@tuservidor.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------
# VARIABLES INTERNAS (no modificar)
# ------------------------------------------

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
VITE_APP_NAME="${APP_NAME}"
