# ==========================================
# rApanel - Entorno Base
# ==========================================

APP_NAME=rApanel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Consulta la lista de zonas válidas aquí: https://www.php.net/manual/es/timezones.php
APP_TIMEZONE="UTC"

# Configuración de Idioma (Disponibles: 'en', 'es', 'pt', 'fr')
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# BASES DE DATOS
# ==========================================

# MySQL Main Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ragnarok
DB_USERNAME=ragnarok
DB_PASSWORD=ragnarok

# MySQL Log Database
DB_LOG_HOST=127.0.0.1
DB_LOG_PORT=3306
DB_LOG_DATABASE=ragnarok
DB_LOG_USERNAME=ragnarok
DB_LOG_PASSWORD=ragnarok

# MySQL Web Database
DB_WEB_HOST=127.0.0.1
DB_WEB_PORT=3306
DB_WEB_DATABASE=ragnarok
DB_WEB_USERNAME=ragnarok
DB_WEB_PASSWORD=ragnarok

# ==========================================
# ESTADO DEL SERVIDOR (Status Checker)
# ==========================================

# Login Server
RA_LOGIN_IP=127.0.0.1
RA_LOGIN_PORT=6900
# Char Server
RA_CHAR_IP=127.0.0.1
RA_CHAR_PORT=6121
# Map Server
RA_MAP_IP=127.0.0.1
RA_MAP_PORT=5121
# Web Server
RA_WEB_IP=127.0.0.1
RA_WEB_PORT=8080

# ==========================================
# CONFIGURACIÓN DE CUENTAS Y PERSONAJES
# ==========================================

# rAthena por defecto es Case-Insensitive (No distingue mayúsculas)
RA_ACCOUNT_NOCASE=true
# Definir si el emulador rathena usa MD5
RA_USE_MD5_PASSWORDS=true
# Define el maximo de cuentas de juego por cuenta maestra
RA_MAX_GAME_ACCOUNTS=3
# Define el reset de posición del personaje
RA_RESET_MAP=prontera
RA_RESET_X=150
RA_RESET_Y=180

# ==========================================
# CONFIGURACIONES DEL PANEL
# ==========================================

RA_REQUIRE_EMAIL_VERIFY=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
